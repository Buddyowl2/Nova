      "parameters": ["id", "radius", "x", "y", "z", "color"],
      "requires_nesting": false,
      "requires_semicolon": false,
      "description": "Renders a circle with a unique ID."
    },
    "nova:create_triangle": {
      "parameters": ["id", "x", "y", "z", "size", "color"],
      "requires_nesting": false,
      "requires_semicolon": false,
      "description": "Renders a triangle with a unique ID."
    },
    "nova:create_rounded_rectangle": {
      "parameters": ["id", "width", "height", "x", "y", "z", "roundness", "color"],
      "requires_nesting": false,
      "requires_semicolon": false,
      "description": "Modern UI box with adjustable corner radius."
    },
