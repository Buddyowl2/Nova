      "parameters": ["id : x : y : z : roundness : size : color"],
      "description": "Soft-edge Reuleaux triangle."
    },
    "nova:create_text": {
      "parameters": ["id : content : x : y : z"],
      "description": "Creates a text element."
    },
    "nova:change_text": {
      "parameters": ["id : new_content"],
      "description": "Updates existing text."
    },
