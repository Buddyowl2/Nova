      "requires_nesting": true
    },
    "nova:wait": {
      "parameters": ["milliseconds"]
    },
    "nova:create_button": {
      "parameters": ["id : x : y : z : roundness : width : height"],
      "requires_semicolon": true,
      "requires_nesting": true,
      "description": "Clickable UI element."
    },
    "nova:save_data": {
